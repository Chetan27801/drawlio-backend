{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"declaration": true,
		"sourceMap": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"baseUrl": "./src",
		"paths": {
			"@config/*": ["config/*"],
			"@core/*": ["core/*"],
			"@game/*": ["game/*"],
			"@services/*": ["services/*"],
			"@utils/*": ["utils/*"],
			"@types/*": ["types/*"],
			"@constants/*": ["constants/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"],
	"ts-node": {
		"require": ["tsconfig-paths/register"]
	}
}
